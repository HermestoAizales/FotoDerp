{
  "name": "fotoerp",
  "version": "0.1.0",
  "description": "Open-source AI-powered photo management for professional photographers",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"wait-on http://localhost:8765/health && electron .\"",
    "start:backend": "cd backend && python3 -m uvicorn fotoerp_backend.main:app --host 0.0.0.0 --port 8765",
    "dev": "NODE_ENV=development electron .",
    "build:backend": "cd backend && python3 build_backend.py",
    "build": "npm run build:backend && electron-builder",
    "build:linux": "npm run build:backend && electron-builder --linux",
    "build:mac": "npm run build:backend && electron-builder --mac",
    "build:win": "npm run build:backend && electron-builder --win"
  },
  "build": {
    "appId": "com.fotoerp.app",
    "productName": "FotoDerp",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "icon": "icons/",
      "category": "Photography",
      "desktop": {
        "Name": "FotoDerp",
        "Comment": "AI-powered photo management",
        "Terminal": "false",
        "Type": "Application"
      }
    },
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "hardenedRuntime": false,
      "extraResources": [
        {
          "from": "electron/uninstall-mac.sh",
          "to": "uninstall-mac.sh"
        }
      ]
    },
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FotoDerp",
      "uninstallDisplayName": "FotoDerp",
      "license": "LICENSE",
      "include": "electron/uninstaller.nsh"
    }
  },
  "keywords": [
    "photo",
    "management",
    "ai",
    "electron"
  ],
  "author": "FotoDerp Contributors",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {}
}
